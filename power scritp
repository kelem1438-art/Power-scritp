-- POWER SCRIPT v1.2 (Ultra RGB Edition)
local Player = game.Players.LocalPlayer
local Mouse = Player:GetMouse()
local UIS = game:GetService("UserInputService")
local RS = game:GetService("RunService")

-- Ayarlar
local SpeedValue = 16
local JumpValue = 50
local Flying = false
local Noclip = false
local FlySpeed = 50

-- UI YARADILMASI
local ScreenGui = Instance.new("ScreenGui", Player:WaitForChild("PlayerGui"))
ScreenGui.Name = "PowerScriptUI"
ScreenGui.ResetOnSpawn = false

local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 350, 0, 450)
MainFrame.Position = UDim2.new(0.5, -175, 0.5, -225)
MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
MainFrame.BorderSizePixel = 6
MainFrame.Draggable = true
MainFrame.Active = true
MainFrame.Visible = false -- CTRL ilə açılacaq

-- RGB BORDER EFFEKTİ (Qalın və Rəngli)
task.spawn(function()
    while true do
        for i = 0, 1, 0.005 do
            MainFrame.BorderColor3 = Color3.fromHSV(i, 1, 1)
            task.wait(0.02)
        end
    end
end)

local Title = Instance.new("TextLabel", MainFrame)
Title.Size = UDim2.new(1, 0, 0, 50)
Title.Text = "POWER SCRIPT [CTRL]"
Title.TextColor3 = Color3.new(1, 1, 1)
Title.TextSize = 22
Title.Font = Enum.Font.GothamBold
Title.BackgroundTransparency = 1

-- SÜRAT (SPEED) YAZI İLƏ
local SpeedBox = Instance.new("TextBox", MainFrame)
SpeedBox.Size = UDim2.new(0, 200, 0, 40)
SpeedBox.Position = UDim2.new(0.5, -100, 0, 70)
SpeedBox.PlaceholderText = "Sürət (məs: 100)"
SpeedBox.Text = ""
SpeedBox.BackgroundColor3 = Color3.fromRGB(30,30,30)
SpeedBox.TextColor3 = Color3.new(1,1,1)

SpeedBox.FocusLost:Connect(function()
    SpeedValue = tonumber(SpeedBox.Text) or 16
end)

-- HOPDANMA (JUMP) YAZI İLƏ
local JumpBox = Instance.new("TextBox", MainFrame)
JumpBox.Size = UDim2.new(0, 200, 0, 40)
JumpBox.Position = UDim2.new(0.5, -100, 0, 120)
JumpBox.PlaceholderText = "Tullanma (məs: 100)"
JumpBox.Text = ""
JumpBox.BackgroundColor3 = Color3.fromRGB(30,30,30)
JumpBox.TextColor3 = Color3.new(1,1,1)

JumpBox.FocusLost:Connect(function()
    JumpValue = tonumber(JumpBox.Text) or 50
end)

-- DÖNGÜ (SPEED/JUMP/NOCLIP ÜÇÜN)
RS.RenderStepped:Connect(function()
    if Player.Character and Player.Character:FindFirstChild("Humanoid") then
        Player.Character.Humanoid.WalkSpeed = SpeedValue
        Player.Character.Humanoid.JumpPower = JumpValue
    end
    
    if Noclip and Player.Character then
        for _, part in pairs(Player.Character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end
end)

-- FLY FUNKSİYASI (Sənin istədiyin: W ilə hərəkət)
local function ToggleFly()
    Flying = not Flying
    if Flying then
        local bv = Instance.new("BodyVelocity", Player.Character.HumanoidRootPart)
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bv.Velocity = Vector3.new(0,0,0)
        bv.Name = "FlyVelocity"
        
        task.spawn(function()
            while Flying do
                local cam = workspace.CurrentCamera
                local dir = Vector3.new(0,0,0)
                if UIS:IsKeyDown(Enum.KeyCode.W) then dir = dir + cam.CFrame.LookVector end
                if UIS:IsKeyDown(Enum.KeyCode.S) then dir = dir - cam.CFrame.LookVector end
                if UIS:IsKeyDown(Enum.KeyCode.A) then dir = dir - cam.CFrame.RightVector end
                if UIS:IsKeyDown(Enum.KeyCode.D) then dir = dir + cam.CFrame.RightVector end
                
                bv.Velocity = dir * FlySpeed
                task.wait()
            end
            bv:Destroy()
        end)
    end
end

-- CTRL İLƏ PANELİ AÇIB-BAĞLAMAQ
UIS.InputBegan:Connect(function(input, gpe)
    if not gpe and input.KeyCode == Enum.KeyCode.LeftControl then
        MainFrame.Visible = not MainFrame.Visible
    end
end)

print("Power Script Aktivdir! Paneli açmaq üçün CTRL bas.")
